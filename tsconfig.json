{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "allowJs": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "rootDir": ".",
    "paths": {
      "#cds-models/*": [
        "./@cds-models/*"
      ],
      "@types/*": [
        "./types/*"
      ]
    },
  },
  "exclude": [
    "app/*/webapp",
    "app/*/dist",
    "app/driver-vue",
    "cli/",
  ]
}
