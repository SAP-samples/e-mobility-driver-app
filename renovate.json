{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "0 0 * * 5"
  ],
  "timezone": "Europe/Paris",
  "labels": [
    "dependencies"
  ],
  "assignees": [],
  "reviewers": [],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 0,
  "separateMajorMinor": true,
  "separateMultipleMajor": true,
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "Group all @sap packages together",
      "groupName": "SAP packages",
      "matchPackagePrefixes": [
        "@sap/"
      ]
    },
    {
      "description": "Group all @ui5 packages together",
      "groupName": "UI5 Web Components",
      "matchPackagePrefixes": [
        "@ui5/"
      ]
    },
    {
      "description": "Group all @types packages together",
      "groupName": "TypeScript types",
      "matchPackagePrefixes": [
        "@types/"
      ]
    },
    {
      "description": "Group ESLint and related packages",
      "groupName": "ESLint and plugins",
      "matchPackagePatterns": [
        "^eslint",
        "^@typescript-eslint/"
      ]
    },
    {
      "description": "Group Vue ecosystem packages",
      "groupName": "Vue ecosystem",
      "matchPackagePatterns": [
        "^vue",
        "^@vue/",
        "^@vitejs/plugin-vue"
      ]
    },
    {
      "description": "Group Vite and related packages",
      "groupName": "Vite and plugins",
      "matchPackagePatterns": [
        "^vite",
        "vite-plugin-"
      ]
    },
    {
      "description": "Group testing packages",
      "groupName": "Testing packages",
      "matchPackagePatterns": [
        "^jest",
        "^vitest",
        "^@vitest/",
        "^@testing-library/"
      ]
    },
    {
      "description": "Group SAP Cloud SDK packages",
      "groupName": "SAP Cloud SDK",
      "matchPackagePrefixes": [
        "@sap-cloud-sdk/"
      ]
    },
    {
      "description": "Automerge minor and patch updates for devDependencies",
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": false
    },
    {
      "description": "Require approval for major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Pin dependencies for Docker and engines",
      "matchDepTypes": [
        "engines"
      ],
      "rangeStrategy": "pin"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "assignees": []
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "0 0 * * 5"
    ]
  },
  "npm": {
    "minimumReleaseAge": "3 days"
  },
  "enabledManagers": [
    "npm",
    "github-actions"
  ],
  "ignoreDeps": [],
  "ignorePaths": [
    "**/node_modules/**",
    "**/dist/**",
    "**/gen/**",
    "**/mta_archives/**"
  ]
}