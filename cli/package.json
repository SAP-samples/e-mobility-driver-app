{
  "name": "driver-app-cli",
  "version": "1.0.0",
  "description": "CLI tools for E-Mobility Driver App development",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "driver-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "cli": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --fix",
    "test": "tsx src/index.ts --help"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@sap/cds": "9.4.4",
    "@types/jsdom": "27.0.0",
    "canvas": "3.2.0",
    "chalk": "5.6.2",
    "commander": "14.0.1",
    "fs-extra": "11.3.2",
    "inquirer": "12.10.0",
    "jsdom": "27.2.0",
    "pdfkit": "0.15.0",
    "qr-code-styling": "1.9.2"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/inquirer": "9.0.9",
    "@types/node": "24.7.2",
    "@types/pdfkit": "0.12.12",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  }
}
