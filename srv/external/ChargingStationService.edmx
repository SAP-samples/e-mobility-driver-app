  <edmx:DataServices>
    <Schema Namespace="emobility.cpo.api.odata.ChargingStationService" xmlns="http://docs.oasis-open.org/odata/ns/edm">
      <Annotation Term="Core.Links">
        <Collection>
          <Record>
            <PropertyValue Property="rel" String="author"/>
            <PropertyValue Property="href" String="https://cap.cloud.sap"/>
          </Record>
        </Collection>
      </Annotation>
      <EntityContainer Name="EntityContainer">
        <EntitySet Name="ChargingStations" EntityType="emobility.cpo.api.odata.ChargingStationService.ChargingStations"/>
        <EntitySet Name="Connectors" EntityType="emobility.cpo.api.odata.ChargingStationService.Connectors"/>
        <EntitySet Name="Coordinates" EntityType="emobility.cpo.api.odata.ChargingStationService.Coordinates"/>
        <EntitySet Name="Addresses" EntityType="emobility.cpo.api.odata.ChargingStationService.Addresses"/>
        <EntitySet Name="EvseLocations" EntityType="emobility.cpo.api.odata.ChargingStationService.EvseLocations">
          <NavigationPropertyBinding Path="address" Target="Addresses"/>
          <NavigationPropertyBinding Path="coordinates" Target="Coordinates"/>
        </EntitySet>
        <EntitySet Name="Evses" EntityType="emobility.cpo.api.odata.ChargingStationService.Evses">
          <NavigationPropertyBinding Path="connectors" Target="Connectors"/>
          <NavigationPropertyBinding Path="location" Target="EvseLocations"/>
          <NavigationPropertyBinding Path="chargingStation" Target="ChargingStations"/>
        </EntitySet>
        <EntitySet Name="ChargingPlans" EntityType="emobility.cpo.api.odata.ChargingStationService.ChargingPlans"/>
      </EntityContainer>
      <EntityType Name="ChargingStations">
        <Key>
          <PropertyRef Name="id"/>
        </Key>
        <Property Name="id" Type="Edm.Guid" Nullable="false"/>
        <Property Name="name" Type="Edm.String" MaxLength="50"/>
        <Property Name="registrationStatus" Type="Edm.String"/>
        <Property Name="siteId" Type="Edm.Guid"/>
        <Property Name="siteAreaId" Type="Edm.Guid"/>
        <Property Name="siteAreaName" Type="Edm.String" MaxLength="100"/>
        <Property Name="siteName" Type="Edm.String" MaxLength="100"/>
        <Property Name="serialNumber" Type="Edm.String"/>
        <Property Name="model" Type="Edm.String" MaxLength="20"/>
        <Property Name="vendor" Type="Edm.String" MaxLength="25"/>
        <Property Name="iccid" Type="Edm.String" MaxLength="20"/>
        <Property Name="imsi" Type="Edm.String" MaxLength="20"/>
        <Property Name="meterType" Type="Edm.String" MaxLength="25"/>
        <Property Name="firmwareVersion" Type="Edm.String" MaxLength="50"/>
        <Property Name="firmwareUpdateStatus" Type="Edm.String" MaxLength="20"/>
        <Property Name="meterSerialNumber" Type="Edm.String" MaxLength="25"/>
        <Property Name="ocppVersion" Type="Edm.String" MaxLength="5"/>
        <Property Name="ocppFormat" Type="Edm.String" MaxLength="4"/>
        <Property Name="publicUrl" Type="Edm.String" MaxLength="2048"/>
        <Property Name="lastSeenAt" Type="Edm.DateTimeOffset" Precision="7"/>
        <Property Name="disabled" Type="Edm.Boolean" DefaultValue="false"/>
        <Property Name="manualConfiguration" Type="Edm.Boolean" DefaultValue="false"/>
        <Property Name="rebootedAt" Type="Edm.DateTimeOffset" Precision="7"/>
        <Property Name="maximumPower" Type="Edm.Double"/>
        <Property Name="voltage" Type="Edm.Int32"/>
        <Property Name="excludedFromDynamicLoadManagement" Type="Edm.Boolean" DefaultValue="false"/>
        <Property Name="ocppStandardParameters" Type="Collection(emobility.cpo.api.odata.ChargingStationService.ChargingStations_ocppStandardParameters)" Nullable="true"/>
        <Property Name="ocppVendorParameters" Type="Collection(emobility.cpo.api.odata.ChargingStationService.ChargingStations_ocppVendorParameters)" Nullable="true"/>
        <Property Name="roaming" Type="Edm.Boolean" DefaultValue="false"/>
      </EntityType>
      <EntityType Name="Connectors">
        <Key>
          <PropertyRef Name="connectorId"/>
        </Key>
        <Property Name="connectorId" Type="Edm.Int32" Nullable="false"/>
        <Property Name="type" Type="Edm.String" MaxLength="10"/>
        <Property Name="currentType" Type="Edm.String" MaxLength="2"/>
        <Property Name="voltage" Type="Edm.Int32"/>
        <Property Name="numberOfPhases" Type="Edm.Double"/>
        <Property Name="evseIndex" Type="Edm.Int32"/>
        <Property Name="current" Type="Edm.Double"/>
        <Property Name="currentLimit" Type="Edm.Double"/>
        <Property Name="status" Type="Edm.String" MaxLength="15"/>
        <Property Name="maximumPower" Type="Edm.Double"/>
      </EntityType>
      <EntityType Name="Coordinates">
        <Property Name="latitude" Type="Edm.String" MaxLength="10"/>
        <Property Name="longitude" Type="Edm.String" MaxLength="11"/>
      </EntityType>
      <EntityType Name="Addresses">
        <Property Name="number" Type="Edm.String" MaxLength="8"/>
        <Property Name="street" Type="Edm.String" MaxLength="36"/>
        <Property Name="postalCode" Type="Edm.String" MaxLength="10"/>
        <Property Name="city" Type="Edm.String" MaxLength="45"/>
        <Property Name="countryCode" Type="Edm.String" MaxLength="3"/>
        <Property Name="country" Type="Edm.String" MaxLength="255"/>
        <Property Name="state" Type="Edm.String" MaxLength="20"/>
      </EntityType>
      <EntityType Name="EvseLocations">
        <Property Name="parkingLevel" Type="Edm.String" MaxLength="32"/>
        <Property Name="parkingName" Type="Edm.String" MaxLength="32"/>
        <Property Name="parkingSpace" Type="Edm.String" MaxLength="32"/>
        <Property Name="companyId" Type="Edm.Guid"/>
        <Property Name="siteId" Type="Edm.Guid"/>
        <Property Name="siteName" Type="Edm.String" MaxLength="100"/>
        <Property Name="siteAreaId" Type="Edm.Guid"/>
        <Property Name="siteAreaName" Type="Edm.String" MaxLength="100"/>
        <NavigationProperty Name="address" Type="emobility.cpo.api.odata.ChargingStationService.Addresses">
          <OnDelete Action="Cascade"/>
        </NavigationProperty>
        <NavigationProperty Name="coordinates" Type="emobility.cpo.api.odata.ChargingStationService.Coordinates">
          <OnDelete Action="Cascade"/>
        </NavigationProperty>
      </EntityType>
      <EntityType Name="Evses">
        <Key>
          <PropertyRef Name="id"/>
        </Key>
        <Property Name="id" Type="Edm.Guid" Nullable="false"/>
        <Property Name="emi3Id" Type="Edm.String" MaxLength="39"/>
        <Property Name="index" Type="Edm.Int32"/>
        <Property Name="code" Type="Edm.String" MaxLength="32"/>
        <Property Name="name" Type="Edm.String" MaxLength="100"/>
        <Property Name="parking" Type="Edm.String" MaxLength="32"/>
        <Property Name="parkingLevel" Type="Edm.String" MaxLength="32"/>
        <Property Name="parkingSpace" Type="Edm.String" MaxLength="32"/>
        <Property Name="chargingStationId" Type="Edm.Guid"/>
        <Property Name="chargingStationName" Type="Edm.String" MaxLength="50"/>
        <NavigationProperty Name="connectors" Type="Collection(emobility.cpo.api.odata.ChargingStationService.Connectors)">
          <OnDelete Action="Cascade"/>
        </NavigationProperty>
        <NavigationProperty Name="location" Type="emobility.cpo.api.odata.ChargingStationService.EvseLocations">
          <OnDelete Action="Cascade"/>
        </NavigationProperty>
        <NavigationProperty Name="chargingStation" Type="emobility.cpo.api.odata.ChargingStationService.ChargingStations">
          <ReferentialConstraint Property="chargingStationId" ReferencedProperty="id"/>
        </NavigationProperty>
      </EntityType>
      <EntityType Name="ChargingSchedule">
        <Property Name="totalDuration" Type="Edm.Double"/>
        <Property Name="startTime" Type="Edm.DateTimeOffset" Precision="7"/>
        <Property Name="periods" Type="Collection(emobility.cpo.api.odata.ChargingStationService.ChargingSchedule_periods)" Nullable="true"/>
      </EntityType>
      <EntityType Name="Profile">
        <Property Name="recurrencePattern" Type="Edm.String" MaxLength="10"/>
        <Property Name="chargingSessionId" Type="Edm.Int32"/>
        <NavigationProperty Name="schedule" Type="emobility.cpo.api.odata.ChargingStationService.ChargingSchedule" ContainsTarget="true"/>
      </EntityType>
      <EntityType Name="ChargingPlans">
        <Key>
          <PropertyRef Name="id"/>
        </Key>
        <Property Name="id" Type="Edm.String" Nullable="false"/>
        <Property Name="evseIndex" Type="Edm.Int32"/>
        <Property Name="connectorId" Type="Edm.Int32"/>
        <Property Name="chargingStationId" Type="Edm.Guid"/>
        <NavigationProperty Name="profile" Type="emobility.cpo.api.odata.ChargingStationService.Profile" ContainsTarget="true"/>
      </EntityType>
      <ComplexType Name="ChargingStations_ocppStandardParameters">
        <Property Name="key" Type="Edm.String"/>
        <Property Name="value" Type="Edm.String"/>
      </ComplexType>
      <ComplexType Name="ChargingStations_ocppVendorParameters">
        <Property Name="key" Type="Edm.String"/>
        <Property Name="value" Type="Edm.String"/>
      </ComplexType>
      <ComplexType Name="emobility_cpo_api_odata_OCPPResetResponse">
        <Property Name="responseCode" Type="Edm.Int32"/>
        <Property Name="responseMessage" Type="Edm.String"/>
        <Property Name="timestamp" Type="Edm.DateTimeOffset" Precision="7"/>
        <Property Name="responseData" Type="emobility.cpo.api.odata.ChargingStationService.emobility_cpo_api_odata_ResponseData"/>
      </ComplexType>
      <ComplexType Name="emobility_cpo_api_odata_ResponseData">
        <Property Name="status" Type="Edm.String"/>
      </ComplexType>
      <ComplexType Name="emobility_cpo_api_odata_OCPPStartResponse">
        <Property Name="responseCode" Type="Edm.Int32"/>
        <Property Name="responseMessage" Type="Edm.String"/>
        <Property Name="timestamp" Type="Edm.DateTimeOffset" Precision="7"/>
        <Property Name="responseData" Type="emobility.cpo.api.odata.ChargingStationService.emobility_cpo_api_odata_ResponseData"/>
      </ComplexType>
      <ComplexType Name="emobility_cpo_api_odata_OCPPStopResponse">
        <Property Name="responseCode" Type="Edm.Int32"/>
        <Property Name="responseMessage" Type="Edm.String"/>
        <Property Name="timestamp" Type="Edm.DateTimeOffset" Precision="7"/>
        <Property Name="responseData" Type="emobility.cpo.api.odata.ChargingStationService.emobility_cpo_api_odata_ResponseData"/>
      </ComplexType>
      <ComplexType Name="emobility_cpo_api_odata_OCPPDataTransferResponse">
        <Property Name="responseCode" Type="Edm.Int32"/>
        <Property Name="responseMessage" Type="Edm.String"/>
        <Property Name="timestamp" Type="Edm.DateTimeOffset" Precision="7"/>
        <Property Name="responseData" Type="emobility.cpo.api.odata.ChargingStationService.emobility_cpo_api_odata_TransferResponseData"/>
      </ComplexType>
      <ComplexType Name="emobility_cpo_api_odata_TransferResponseData">
        <Property Name="status" Type="Edm.String"/>
        <Property Name="data" Type="Edm.String"/>
      </ComplexType>
      <ComplexType Name="emobility_cpo_api_odata_Data">
        <Property Name="vendorId" Type="Edm.String" MaxLength="255" Nullable="false"/>
        <Property Name="messageId" Type="Edm.String" MaxLength="50"/>
        <Property Name="data" Type="Edm.String"/>
      </ComplexType>
      <ComplexType Name="ChargingSchedule_periods">
        <Property Name="startPeriod" Type="Edm.Double"/>
        <Property Name="limit" Type="Edm.Double"/>
        <Property Name="numberPhases" Type="Edm.Int32"/>
      </ComplexType>
      <Action Name="Reset" IsBound="true">
        <Parameter Name="in" Type="emobility.cpo.api.odata.ChargingStationService.ChargingStations"/>
        <Parameter Name="type" Type="Edm.String"/>
        <ReturnType Type="emobility.cpo.api.odata.ChargingStationService.emobility_cpo_api_odata_OCPPResetResponse"/>
      </Action>
      <Action Name="Start" IsBound="true">
        <Parameter Name="in" Type="emobility.cpo.api.odata.ChargingStationService.ChargingStations"/>
        <Parameter Name="badgeAuthenticationId" Type="Edm.String"/>
        <Parameter Name="connectorId" Type="Edm.Int32"/>
        <ReturnType Type="emobility.cpo.api.odata.ChargingStationService.emobility_cpo_api_odata_OCPPStartResponse"/>
      </Action>
      <Action Name="Stop" IsBound="true">
        <Parameter Name="in" Type="emobility.cpo.api.odata.ChargingStationService.ChargingStations"/>
        <Parameter Name="chargingSessionId" Type="Edm.Int32"/>
        <ReturnType Type="emobility.cpo.api.odata.ChargingStationService.emobility_cpo_api_odata_OCPPStopResponse"/>
      </Action>
      <Action Name="TransferData" IsBound="true">
        <Parameter Name="in" Type="emobility.cpo.api.odata.ChargingStationService.ChargingStations"/>
        <Parameter Name="data" Type="emobility.cpo.api.odata.ChargingStationService.emobility_cpo_api_odata_Data"/>
        <ReturnType Type="emobility.cpo.api.odata.ChargingStationService.emobility_cpo_api_odata_OCPPDataTransferResponse"/>
      </Action>
      <Action Name="ChangeSiteArea" IsBound="true">
        <Parameter Name="in" Type="emobility.cpo.api.odata.ChargingStationService.ChargingStations"/>
        <Parameter Name="siteAreaId" Type="Edm.Guid"/>
        <ReturnType Type="Edm.String"/>
      </Action>
      <Action Name="ChangeRoamingFlag" IsBound="true">
        <Parameter Name="in" Type="emobility.cpo.api.odata.ChargingStationService.ChargingStations"/>
        <Parameter Name="roaming" Type="Edm.Boolean"/>
      </Action>
      <Annotation Term="Core.SchemaVersion" String="1.0"/>
      <Annotation Term="Core.DefaultNamespace" Bool="true"/>
      <Annotations Target="emobility.cpo.api.odata.ChargingStationService.EntityContainer">
        <Annotation Term="Common.Label" String="Charging Station"/>
        <Annotation Term="Core.Description" String="Manage your charging stations"/>
        <Annotation Term="Core.LongDescription" String="Retrieve charging station information, such as details related to your EVSEs (Electric Vehicle Supply Equipments)."/>
        <Annotation Term="Authorization.Authorizations">
          <Collection>
            <Record Type="Authorization.OAuth2ClientCredentials">
              <PropertyValue Property="Name" String="oAuth2"/>
              <PropertyValue Property="Description" String="Authentication via OAuth2 with client credentials flow"/>
              <PropertyValue Property="TokenUrl" String="https://{identityzone}.authentication.{region}.hana.ondemand.com/oauth/token"/>
              <PropertyValue Property="Scopes">
                <Collection>
                  <Record Type="Authorization.AuthorizationScope">
                    <PropertyValue Property="Scope" String="SAP_EMO_API_EVSE_READ"/>
                    <PropertyValue Property="Description" String="Retrieves EVSEs."/>
                  </Record>
                  <Record Type="Authorization.AuthorizationScope">
                    <PropertyValue Property="Scope" String="API_EVSE_READ"/>
                    <PropertyValue Property="Description" String="Retrieves EVSEs."/>
                  </Record>
                  <Record Type="Authorization.AuthorizationScope">
                    <PropertyValue Property="Scope" String="API_EVSE_UPDATE"/>
                    <PropertyValue Property="Description" String="Updates EVSEs."/>
                  </Record>
                  <Record Type="Authorization.AuthorizationScope">
                    <PropertyValue Property="Scope" String="API_CHARGINGSTATION_READ"/>
                    <PropertyValue Property="Description" String="Retrieves charging stations."/>
                  </Record>
                  <Record Type="Authorization.AuthorizationScope">
                    <PropertyValue Property="Scope" String="API_CHARGINGSTATION_TRANSFERDATA"/>
                    <PropertyValue Property="Description" String="Transfers vendor-specific data to a charging station."/>
                  </Record>
                  <Record Type="Authorization.AuthorizationScope">
                    <PropertyValue Property="Scope" String="API_CHARGINGSTATION_RESET"/>
                    <PropertyValue Property="Description" String="Reboots (hard resets) and soft resets charging stations."/>
                  </Record>
                  <Record Type="Authorization.AuthorizationScope">
                    <PropertyValue Property="Scope" String="API_CHARGINGSTATION_START"/>
                    <PropertyValue Property="Description" String="Starts charging sessions on charging stations."/>
                  </Record>
                  <Record Type="Authorization.AuthorizationScope">
                    <PropertyValue Property="Scope" String="API_CHARGINGSTATION_STOP"/>
                    <PropertyValue Property="Description" String="Stops charging sessions on charging stations."/>
                  </Record>
                  <Record Type="Authorization.AuthorizationScope">
                    <PropertyValue Property="Scope" String="API_CHARGINGSTATION_UPDATE"/>
                    <PropertyValue Property="Description" String="Assigns a charging station to another site area."/>
                  </Record>
                  <Record Type="Authorization.AuthorizationScope">
                    <PropertyValue Property="Scope" String="API_CHARGINGPLAN_CREATE"/>
                    <PropertyValue Property="Description" String="Creates a charging plan for a charging station."/>
                  </Record>
                  <Record Type="Authorization.AuthorizationScope">
                    <PropertyValue Property="Scope" String="API_CHARGINGPLAN_UPDATE"/>
                    <PropertyValue Property="Description" String="Updates a charging plan for a charging station."/>
                  </Record>
                  <Record Type="Authorization.AuthorizationScope">
                    <PropertyValue Property="Scope" String="API_CHARGINGPLAN_READ"/>
                    <PropertyValue Property="Description" String="Retrieves charging plans."/>
                  </Record>
                  <Record Type="Authorization.AuthorizationScope">
                    <PropertyValue Property="Scope" String="API_CHARGINGPLAN_DELETE"/>
                    <PropertyValue Property="Description" String="Deletes charging plans."/>
                  </Record>
                </Collection>
              </PropertyValue>
            </Record>
          </Collection>
        </Annotation>
        <Annotation Term="Capabilities.BatchSupported" Bool="false"/>
        <Annotation Term="Capabilities.DeepUpdateSupport">
          <Record Type="Capabilities.DeepUpdateSupportType">
            <PropertyValue Property="Supported" Bool="true"/>
          </Record>
        </Annotation>
      </Annotations>
      <Annotations Target="emobility.cpo.api.odata.ChargingStationService.ChargingStations">
        <Annotation Term="Common.Label" String="Charging Stations"/>
      </Annotations>
      <Annotations Target="emobility.cpo.api.odata.ChargingStationService.EntityContainer/ChargingStations">
        <Annotation Term="Capabilities.ReadRestrictions">
          <Record Type="Capabilities.ReadRestrictionsType">
            <PropertyValue Property="Description" String="Retrieves a list of charging stations."/>
            <PropertyValue Property="LongDescription" String="Use the following request to fetch data related to your charging stations."/>
            <PropertyValue Property="ReadByKeyRestrictions">
              <Record Type="Capabilities.ReadByKeyRestrictionsType">
                <PropertyValue Property="Description" String="Retrieves a charging station with a specific identifier."/>
                <PropertyValue Property="LongDescription" String="Use the following request to fetch data related to a charging station by providing its ID."/>
              </Record>
            </PropertyValue>
            <PropertyValue Property="Readable" Bool="true"/>
          </Record>
        </Annotation>
        <Annotation Term="Capabilities.UpdateRestrictions">
          <Record Type="Capabilities.UpdateRestrictionsType">
            <PropertyValue Property="Updatable" Bool="false"/>
          </Record>
        </Annotation>
        <Annotation Term="Capabilities.InsertRestrictions">
          <Record Type="Capabilities.InsertRestrictionsType">
            <PropertyValue Property="Insertable" Bool="false"/>
          </Record>
        </Annotation>
        <Annotation Term="Capabilities.DeleteRestrictions">
          <Record Type="Capabilities.DeleteRestrictionsType">
            <PropertyValue Property="Deletable" Bool="false"/>
          </Record>
        </Annotation>
      </Annotations>
