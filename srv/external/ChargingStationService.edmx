        <Annotation Term="Core.ComputedDefaultValue" Bool="true"/>
      </Annotations>
      <Annotations Target="emobility.cpo.api.odata.ChargingStationService.Evses/emi3Id">
        <Annotation Term="Core.LongDescription" String="The eMI³ ID of the EVSE"/>
        <Annotation Term="Core.Example">
          <Record Type="Core.PrimitiveExampleValue">
            <PropertyValue Property="Value" String="DE*ABC*E1a2b3c"/>
          </Record>
        </Annotation>
        <Annotation Term="Validation.Pattern" String="(^$)|^[A-Za-z]{2}\*[0-9A-Za-z]{3}\*E[0-9A-Za-z][0-9A-Za-z\*]{0,30}$"/>
      </Annotations>
