      <Annotations Target="emobility.cpo.api.odata.ChargingStationService.Evses">
        <Annotation Term="Common.Label" String="EVSEs"/>
      </Annotations>
      <Annotations Target="emobility.cpo.api.odata.ChargingStationService.EntityContainer/Evses">
        <Annotation Term="Capabilities.ReadRestrictions">
          <Record Type="Capabilities.ReadRestrictionsType">
            <PropertyValue Property="Description" String="Retrieves a list of EVSEs."/>
            <PropertyValue Property="LongDescription" String="Use the following request to fetch data related to your charging station EVSEs. &lt;br>An EVSE (Electric Vehicle Supply Equipment) is the independently operated and managed part of a charging station that can deliver energy to one vehicle at a time."/>
            <PropertyValue Property="ReadByKeyRestrictions">
              <Record Type="Capabilities.ReadByKeyRestrictionsType">
                <PropertyValue Property="Description" String="Retrieves an EVSE with a specific identifier."/>
                <PropertyValue Property="LongDescription" String="Use the following request to fetch data related to the EVSE of a charging station by providing the EVSE ID. &lt;br>An EVSE (Electric Vehicle Supply Equipment) is the independently operated and managed part of a charging station that can deliver energy to one vehicle at a time."/>
              </Record>
            </PropertyValue>
            <PropertyValue Property="Readable" Bool="true"/>
          </Record>
        </Annotation>
        <Annotation Term="Capabilities.UpdateRestrictions">
          <Record Type="Capabilities.UpdateRestrictionsType">
            <PropertyValue Property="Description" String="Updates an EVSE."/>
            <PropertyValue Property="LongDescription" String="Use the following request to update an EVSE. &lt;br>An EVSE (Electric Vehicle Supply Equipment) is the independently operated and managed part of a charging station that can deliver energy to one vehicle at a time."/>
            <PropertyValue Property="Updatable" Bool="true"/>
            <PropertyValue Property="UpdateMethod" EnumMember="Capabilities.HttpMethod/PATCH"/>
          </Record>
        </Annotation>
        <Annotation Term="Capabilities.InsertRestrictions">
          <Record Type="Capabilities.InsertRestrictionsType">
            <PropertyValue Property="Insertable" Bool="false"/>
          </Record>
        </Annotation>
        <Annotation Term="Capabilities.DeleteRestrictions">
          <Record Type="Capabilities.DeleteRestrictionsType">
            <PropertyValue Property="Deletable" Bool="false"/>
          </Record>
        </Annotation>
      </Annotations>
      <Annotations Target="emobility.cpo.api.odata.ChargingStationService.Evses/id">
