        <Property Name="badgeAuthenticationId" Type="Edm.String"/>
        <Property Name="badgeVisualBadgeId" Type="Edm.String"/>
        <Property Name="startMeterValue" Type="Edm.Double"/>
        <Property Name="timestamp" Type="Edm.DateTimeOffset" Precision="7"/>
        <Property Name="cumulatedPrice" Type="Edm.Double"/>
        <Property Name="pricePerKwh" Type="Edm.Double"/>
        <Property Name="currency" Type="Edm.String"/>
        <Property Name="cumulatedSalesAmount" Type="Edm.Double"/>
        <Property Name="salesAmountPerKwh" Type="Edm.Double"/>
        <Property Name="salesAmountCurrency" Type="Edm.String"/>
        <Property Name="stateOfCharge" Type="Edm.Double"/>
        <Property Name="timezone" Type="Edm.String"/>
        <Property Name="currentTimestamp" Type="Edm.DateTimeOffset" Precision="7"/>
        <Property Name="totalInactivity" Type="Edm.Double"/>
        <Property Name="totalDuration" Type="Edm.Double"/>
        <Property Name="status" Type="Edm.String"/>
        <NavigationProperty Name="errors" Type="Collection(emobility.cpo.api.odata.ChargingSessionService.Errors)">
          <OnDelete Action="Cascade"/>
        </NavigationProperty>
        <Property Name="connectorStatus" Type="Edm.String"/>
        <Property Name="numberOfMeterValues" Type="Edm.Double"/>
        <Property Name="vehicleModelId" Type="Edm.String" MaxLength="36"/>
        <Property Name="connectorId" Type="Edm.Int32"/>
        <Property Name="startSignedMeterValue" Type="Edm.String"/>
        <NavigationProperty Name="stop" Type="emobility.cpo.api.odata.ChargingSessionService.Stops">
          <OnDelete Action="Cascade"/>
        </NavigationProperty>
        <NavigationProperty Name="remoteStop" Type="emobility.cpo.api.odata.ChargingSessionService.RemoteStops">
          <OnDelete Action="Cascade"/>
        </NavigationProperty>
        <NavigationProperty Name="authorization" Type="emobility.cpo.api.odata.ChargingSessionService.Authorizations">
          <ReferentialConstraint Property="authorization_ID" ReferencedProperty="id"/>
        </NavigationProperty>
        <Property Name="authorization_ID" Type="Edm.Guid"/>
        <Property Name="evseCode" Type="Edm.String" MaxLength="32"/>
        <Property Name="emi3Id" Type="Edm.String" MaxLength="39"/>
        <Property Name="chargingStationName" Type="Edm.String" MaxLength="50"/>
        <Property Name="badgeProviderId" Type="Edm.String" MaxLength="64"/>
        <Property Name="validationChannel" Type="Edm.String"/>
      </EntityType>
      <EntityType Name="ChargeDetailRecords">
        <Key>
          <PropertyRef Name="id"/>
        </Key>
        <Property Name="id" Type="Edm.Guid" Nullable="false"/>
        <Property Name="source" Type="Edm.String"/>
        <Property Name="badgeAuthenticationId" Type="Edm.String"/>
