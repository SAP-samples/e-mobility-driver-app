        <EntitySet Name="Stops" EntityType="emobility.cpo.api.odata.ChargingSessionService.Stops"/>
        <EntitySet Name="ChargingSessions" EntityType="emobility.cpo.api.odata.ChargingSessionService.ChargingSessions">
          <NavigationPropertyBinding Path="errors" Target="Errors"/>
          <NavigationPropertyBinding Path="stop" Target="Stops"/>
          <NavigationPropertyBinding Path="remoteStop" Target="RemoteStops"/>
          <NavigationPropertyBinding Path="authorization" Target="Authorizations"/>
        </EntitySet>
        <EntitySet Name="ChargeDetailRecords" EntityType="emobility.cpo.api.odata.ChargingSessionService.ChargeDetailRecords"/>
        <ActionImport Name="CalculateChargingPeriods" Action="emobility.cpo.api.odata.ChargingSessionService.CalculateChargingPeriods"/>
      </EntityContainer>
      <EntityType Name="Authorizations">
        <Key>
          <PropertyRef Name="id"/>
        </Key>
