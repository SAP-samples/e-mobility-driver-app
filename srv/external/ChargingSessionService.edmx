      </EntityType>
      <EntityType Name="ChargingSessions">
        <Key>
          <PropertyRef Name="id"/>
        </Key>
        <Property Name="id" Type="Edm.Int32" Nullable="false"/>
        <Property Name="sessionId" Type="Edm.Guid"/>
        <Property Name="siteId" Type="Edm.Guid"/>
        <Property Name="siteAreaId" Type="Edm.Guid"/>
