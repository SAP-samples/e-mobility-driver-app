        <Property Name="stopTimestamp" Type="Edm.DateTimeOffset" Precision="7"/>
        <Property Name="duration" Type="Edm.Double"/>
        <Property Name="inactivity" Type="Edm.Double"/>
        <Property Name="energyDelivered" Type="Edm.Double"/>
