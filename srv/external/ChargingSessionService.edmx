      <EntityContainer Name="EntityContainer">
        <EntitySet Name="Authorizations" EntityType="emobility.cpo.api.odata.ChargingSessionService.Authorizations"/>
        <EntitySet Name="Sessions" EntityType="emobility.cpo.api.odata.ChargingSessionService.Sessions"/>
        <EntitySet Name="ErrorMessages" EntityType="emobility.cpo.api.odata.ChargingSessionService.ErrorMessages"/>
